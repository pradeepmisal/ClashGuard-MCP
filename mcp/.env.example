# Autodesk Platform Services (APS) — needed for live Revit data
APS_CLIENT_ID=your_aps_client_id_here
APS_CLIENT_SECRET=your_aps_client_secret_here

# Anthropic Claude API — needed for Tool 4 (suggest_resolutions) if using Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini Free API (Alternative) — Google AI Studio API keys are free
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Demo mode — set true to use mock_db.json instead of live APS
DEMO_MODE=true

# Optional: path to C# Revit plugin JSON export (real Revit data, no APS needed)
CSHARP_EXPORT_PATH=C:\Users\YourName\Desktop\clashguard_payloads.json
